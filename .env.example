# Copy to .env (or `.env.local`) and tweak for your environment.
# `docker compose up` reads .env automatically; `JWT_KEY` is the only
# REQUIRED variable — the backend container refuses to boot without it.

# --- required --------------------------------------------------------------

# >= 32 bytes. Generate one with: `openssl rand -base64 48`
# This signs every JWT (access tokens, password resets, email verifies, etc).
# Rotating the key invalidates every outstanding token in one go.
JWT_KEY=replace-me-with-a-long-random-string-of-at-least-32-bytes

# --- public origin ---------------------------------------------------------

# Used for the URLs embedded in verification and reset emails AND as the
# CORS allowed origin (a no-op when same-origin via nginx, but applies if
# you bypass it). Set to your https://... in production.
PUBLIC_ORIGIN=http://localhost

# Host port nginx binds. Default 80; set to 8080 if you have something else
# on 80 already.
PUBLIC_PORT=80

# --- WebAuthn / passkeys ---------------------------------------------------

# Relying-party id is the public hostname only — no scheme, no port. For
# localhost the browser allows the default; for production set this to your
# hostname (e.g. "sverre.dev").
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=sverre.dev

# --- email -----------------------------------------------------------------

# Defaults wire to the Mailpit container in compose. To send real mail in
# production, point these at your SMTP provider.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=noreply@example.com

# --- location feature ------------------------------------------------------

# Required by Nominatim's usage policy: a real User-Agent including a
# contact address. Without it the public Nominatim service will block
# requests. Self-hosters can also point Location__NominatimBaseUrl at
# their own instance to avoid the rate limit entirely.
LOCATION_USER_AGENT=sverre.dev (set in .env to your contact email)
