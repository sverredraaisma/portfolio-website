{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=portfolio;Username=portfolio;Password=portfolio"
  },
  "Jwt": {
    "Issuer": "portfolio-api",
    "Audience": "portfolio-frontend",
    "//Key": "Set Jwt:Key via env var Jwt__Key, user-secrets, or a vault. App refuses to start without one >= 32 bytes.",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30,
    "EmailVerifyHours": 24
  },
  "Cors": {
    "FrontendOrigin": "http://localhost:3000"
  },
  "Email": {
    "From": "noreply@example.com",
    "SmtpHost": "localhost",
    "SmtpPort": 1025,
    "SmtpUser": "",
    "SmtpPassword": "",
    "VerifyUrlBase": "http://localhost:3000/verify"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5080"
      }
    }
  }
}
